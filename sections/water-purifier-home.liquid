{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .water-home-{{ section.id }} {
    background:
      radial-gradient(circle at top left, rgba(126, 214, 255, 0.18), transparent 26%),
      linear-gradient(180deg, #f7fcff 0%, #eef9ff 100%);
  }

  .water-home-{{ section.id }} .page-width {
    display: grid;
    gap: 3.2rem;
  }

  .water-home-{{ section.id }}__intro {
    display: grid;
    gap: 1.6rem;
  }

  .water-home-{{ section.id }}__eyebrow {
    margin: 0;
    color: #0b6ea8;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .water-home-{{ section.id }}__heading {
    margin: 0;
    max-width: 72rem;
    color: #09253d;
  }

  .water-home-{{ section.id }}__subtext {
    margin: 0;
    max-width: 76rem;
    color: rgba(9, 37, 61, 0.78);
    font-size: 1.7rem;
    line-height: 1.7;
  }

  .water-home-{{ section.id }}__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .water-home-{{ section.id }}__chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 1.6rem;
    border: 1px solid rgba(11, 110, 168, 0.14);
    border-radius: 999px;
    background: #ffffff;
    color: #0b4263;
    font-size: 1.4rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    box-shadow: 0 10px 24px rgba(11, 110, 168, 0.06);
  }

  .water-home-{{ section.id }}__chip:hover {
    transform: translateY(-2px);
    border-color: rgba(11, 110, 168, 0.3);
    box-shadow: 0 14px 28px rgba(11, 110, 168, 0.12);
  }

  .water-home-{{ section.id }}__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.8rem;
  }

  .water-home-{{ section.id }}__card {
    position: relative;
    overflow: hidden;
    padding: 2.4rem;
    border-radius: 2.4rem;
    background: linear-gradient(180deg, #ffffff 0%, #f2fbff 100%);
    box-shadow: 0 20px 45px rgba(23, 84, 126, 0.1);
  }

  .water-home-{{ section.id }}__card::after {
    content: '';
    position: absolute;
    inset: auto -30% -35% auto;
    width: 18rem;
    height: 18rem;
    border-radius: 50%;
    background: rgba(117, 214, 255, 0.16);
  }

  .water-home-{{ section.id }}__card-tag {
    display: inline-flex;
    margin-bottom: 1.2rem;
    padding: 0.6rem 1rem;
    border-radius: 999px;
    background: #dff5ff;
    color: #0b6ea8;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .water-home-{{ section.id }}__card h3,
  .water-home-{{ section.id }}__trust h3,
  .water-home-{{ section.id }}__faq h3 {
    margin: 0 0 0.8rem;
    color: #09253d;
  }

  .water-home-{{ section.id }}__card p,
  .water-home-{{ section.id }}__trust p,
  .water-home-{{ section.id }}__faq p {
    margin: 0;
    color: rgba(9, 37, 61, 0.76);
    line-height: 1.7;
  }

  .water-home-{{ section.id }}__card-link {
    display: inline-flex;
    margin-top: 1.6rem;
    color: #0b6ea8;
    font-size: 1.4rem;
    font-weight: 700;
    text-decoration: none;
  }

  .water-home-{{ section.id }}__trust-row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.6rem;
  }

  .water-home-{{ section.id }}__trust {
    padding: 2rem;
    border: 1px solid rgba(11, 110, 168, 0.12);
    border-radius: 2rem;
    background: rgba(255, 255, 255, 0.84);
    backdrop-filter: blur(6px);
  }

  .water-home-{{ section.id }}__icon {
    width: 4.8rem;
    height: 4.8rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.2rem;
    border-radius: 1.4rem;
    background: linear-gradient(180deg, #dff5ff 0%, #b9ebff 100%);
    color: #0b6ea8;
  }

  .water-home-{{ section.id }}__faq-list {
    display: grid;
    gap: 1.2rem;
  }

  .water-home-{{ section.id }}__faq {
    padding: 0 2rem;
    border: 1px solid rgba(11, 110, 168, 0.12);
    border-radius: 1.8rem;
    background: #ffffff;
    box-shadow: 0 10px 28px rgba(23, 84, 126, 0.06);
  }

  .water-home-{{ section.id }}__faq summary {
    cursor: pointer;
    list-style: none;
    padding: 2rem 0;
    color: #09253d;
    font-size: 1.7rem;
    font-weight: 700;
  }

  .water-home-{{ section.id }}__faq summary::-webkit-details-marker {
    display: none;
  }

  .water-home-{{ section.id }}__faq-content {
    padding-bottom: 2rem;
  }

  @media screen and (max-width: 989px) {
    .water-home-{{ section.id }}__grid,
    .water-home-{{ section.id }}__trust-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
    }

    .water-home-{{ section.id }} .page-width {
      gap: 2.4rem;
    }

    .water-home-{{ section.id }}__heading {
      font-size: calc(var(--font-heading-scale) * 3rem);
    }

    .water-home-{{ section.id }}__subtext {
      font-size: 1.5rem;
    }

    .water-home-{{ section.id }}__grid,
    .water-home-{{ section.id }}__trust-row {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<div class="water-home-{{ section.id }} section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="water-home-{{ section.id }}__intro">
      <p class="water-home-{{ section.id }}__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="water-home-{{ section.id }}__heading inline-richtext {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
      <p class="water-home-{{ section.id }}__subtext">{{ section.settings.subtext }}</p>
      <div class="water-home-{{ section.id }}__chips">
        {%- for block in section.blocks -%}
          {%- if block.type == 'category' -%}
            <a
              class="water-home-{{ section.id }}__chip"
              {% if block.settings.link != blank %}
                href="{{ block.settings.link }}"
              {% else %}
                role="link" aria-disabled="true"
              {% endif %}
              {{ block.shopify_attributes }}
            >
              {{ block.settings.label }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="water-home-{{ section.id }}__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'highlight' -%}
          <article class="water-home-{{ section.id }}__card" {{ block.shopify_attributes }}>
            <span class="water-home-{{ section.id }}__card-tag">{{ block.settings.tag }}</span>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
            {%- if block.settings.link_label != blank -%}
              <a
                class="water-home-{{ section.id }}__card-link"
                {% if block.settings.link != blank %}
                  href="{{ block.settings.link }}"
                {% else %}
                  role="link" aria-disabled="true"
                {% endif %}
              >
                {{ block.settings.link_label }}
              </a>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="water-home-{{ section.id }}__trust-row">
      {%- for block in section.blocks -%}
        {%- if block.type == 'trust' -%}
          <article class="water-home-{{ section.id }}__trust" {{ block.shopify_attributes }}>
            <div class="water-home-{{ section.id }}__icon">
              <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true" focusable="false">
                {%- case block.settings.icon -%}
                  {%- when 'shield' -%}
                    <path d="M12 2 5 5v6c0 5 3.4 9.7 7 11 3.6-1.3 7-6 7-11V5l-7-3Zm0 5a3 3 0 1 1 0 6 3 3 0 0 1 0-6Zm0 12c-2.1-.9-4-3.1-4.9-5.8.9-.7 2.3-1.2 4.9-1.2s4 .5 4.9 1.2C16 15.9 14.1 18.1 12 19Z" fill="currentColor"/>
                  {%- when 'refresh' -%}
                    <path d="M12 5a7 7 0 0 1 6.3 4H16l4 4 4-4h-2.6A10 10 0 1 0 22 14h-3a7 7 0 1 1-7-9Z" fill="currentColor"/>
                  {%- when 'wallet' -%}
                    <path d="M3 6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v1h1a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6Zm16 3v7h1V9h-1Zm-1 7V7H5v9h13Zm-3-5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3Z" fill="currentColor"/>
                  {%- else -%}
                    <path d="M12 2c3 3.6 6 6.8 6 10.5A6 6 0 1 1 6 12.5C6 8.8 9 5.6 12 2Zm0 4.5c-1.8 2.2-3 4-3 6a3 3 0 1 0 6 0c0-2-1.2-3.8-3-6Z" fill="currentColor"/>
                {%- endcase -%}
              </svg>
            </div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="water-home-{{ section.id }}__faq-list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq' -%}
          <details class="water-home-{{ section.id }}__faq" {{ block.shopify_attributes }}>
            <summary>{{ block.settings.question }}</summary>
            <div class="water-home-{{ section.id }}__faq-content">
              <p>{{ block.settings.answer }}</p>
            </div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Water Purifier Home",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Water Purifier Range"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Explore the right purifier for every home"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h1",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ]
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "A clean category-led layout with offers, trust signals, and helpful FAQs to guide customers from browsing to purchase."
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category chip",
      "limit": 10,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "RO Water Purifier"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "highlight",
      "name": "Highlight card",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "tag",
          "label": "Tag",
          "default": "Best Seller"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Multi-stage RO purification"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Create feature-driven promo cards that bring attention to your top purifier categories and offers."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "trust",
      "name": "Trust point",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "shield",
          "options": [
            { "value": "shield", "label": "Shield" },
            { "value": "refresh", "label": "Refresh" },
            { "value": "wallet", "label": "Wallet" },
            { "value": "drop", "label": "Drop" }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Safe purification"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Highlight the reason customers should trust your purifier store and after-sales support."
        }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Which water purifier is best for home use?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Choose based on your water source, TDS level, family size, and the features you want like RO, UV, UF, copper, or alkaline enhancement."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Water Purifier Home",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "highlight" },
        { "type": "highlight" },
        { "type": "highlight" },
        { "type": "trust" },
        { "type": "trust" },
        { "type": "trust" },
        { "type": "trust" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}
